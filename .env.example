# API Configuration
API_HOST=0.0.0.0
API_PORT=7501
API_WORKERS=1

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:7500

# Frontend Configuration
FRONTEND_URL=http://localhost:7500
FASTAPI_URL=http://localhost:7501

# ExerciseDB API Configuration
# Get your free API key from: https://rapidapi.com/justin-WFnsXH_t6/api/exercisedb
EXERCISEDB_API_URL=https://oss.exercisedb.dev/api/v1/exercises
EXERCISEDB_API_KEY=your_rapidapi_key_here
EXERCISEDB_PAGE_SIZE=100

# Vector Database
CHROMA_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# LLM CONFIGURATION - LAZY LOADING (RECOMMENDED)
# ============================================================
# IMPORTANT: Models are loaded ON-DEMAND to save memory!
#
# RECOMMENDED SETUP (Lazy Loading):
# 1. Set USE_GGUF=false (default)
# 2. Select your model dynamically in the web UI
# 3. Models load only when you generate a workout
# ============================================================

# Option 1: Local GGUF Models with LangChain (requires llama-cpp-python)
# Set USE_GGUF=true to use GGUF models via LangChain
USE_GGUF=false
GGUF_MODEL_PATH=/path/to/your/model.gguf
GGUF_N_CTX=4096
GGUF_N_GPU_LAYERS=0

# Option 2: Local Servers (LM Studio, OLLAMA, OMLX, etc.)
# Set USE_GGUF=false to use a local server.
#
# ── LM Studio (port 1234) ──────────────────────────────────────────────
# Running locally (no Docker):   http://127.0.0.1:1234/v1
# Running in Docker / Colima:    http://host.docker.internal:1234/v1
# API Key: leave empty or use 'lm-studio'
# IMPORTANT: In LM Studio → Local Server → Server Options,
#   enable "Serve on Local Network" so it binds to 0.0.0.0.
#
# ── OMLX (port 8000) ──────────────────────────────────────────────────
# Running locally (no Docker):   http://127.0.0.1:8000/v1
# Running in Docker / Colima:    http://host.docker.internal:8000/v1
# Start: omlx serve --host 0.0.0.0 --port 8000 --model <model>
# API Key: set LLM_API_KEY to your OMLX key, or leave empty if none
#
# ── OLLAMA ─────────────────────────────────────────────────────────────
# Running locally (no Docker):   http://127.0.0.1:11434/v1
# Running in Docker / Colima:    http://host.docker.internal:11434/v1
# Start: OLLAMA_HOST=0.0.0.0 ollama serve

# -- Set the URLs for your server --
# LLM_BASE_URL        → used when running the server locally (no Docker)
# LLM_BASE_URL_DOCKER → used inside Docker / Colima (overrides LLM_BASE_URL)
# Set both so the app works in both runtimes without changing .env each time.
OMLX_BASE_URL=http://127.0.0.1:8000/v1
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_BASE_URL_DOCKER=http://host.docker.internal:1234/v1

# LLM_MODEL is optional for local servers (LM Studio, OMLX, OLLAMA).
# If left blank the server is queried at startup and the first available
# model is selected automatically.
LLM_MODEL=

# Option 3: Public LLM APIs (OpenAI, Anthropic, etc.)
# Set USE_GGUF=false and provide API key + base URL
# For OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
# For Anthropic:
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_API_KEY=sk-ant-...
# For Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_API_KEY=gsk_...
LLM_API_KEY=

# Common LLM Parameters (applies to all options)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=32000

# Logging
LOG_LEVEL=INFO

# Made with Bob