# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ExerciseDB API
EXERCISEDB_API_URL=https://oss.exercisedb.dev/api/v1/exercises
EXERCISEDB_PAGE_SIZE=100

# Vector Database
CHROMA_DB_PATH=./data/chroma_db
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# LLM CONFIGURATION - Choose ONE option below
# ============================================================

# Option 1: Local MLX Models (RECOMMENDED - No API costs, runs on Mac)
# Set USE_MLX=true to use local MLX models with agent capabilities
USE_MLX=true

# Available local models in ~/.lmstudio/models/mlx-community/:
# - Llama-3.2-3B-Instruct-4bit (1.7GB) - Fast, good for quick responses
# - Qwen3.5-4B-MLX-4bit (2.5GB) - Good balance of speed and quality (RECOMMENDED)
# - Qwen3.5-9B-MLX-4bit (5.6GB) - Better quality, moderate speed
# - Qwen3.6-27B-4bit (15GB) - Best quality, slower
MLX_MODEL_PATH=/Users/adithyanair/.lmstudio/models/mlx-community/Qwen3.5-4B-MLX-4bit

# Option 2: Local GGUF Models with LangChain (Alternative local option)
# Set USE_GGUF=true to use GGUF models via LangChain (requires llama-cpp-python)
USE_GGUF=false
GGUF_MODEL_PATH=/path/to/your/model.gguf
GGUF_N_CTX=4096
GGUF_N_GPU_LAYERS=0

# Option 3: Local Servers (LM Studio, OLLAMA, OMLX, etc.)
# Set USE_MLX=false and USE_GGUF=false to use local server
# Options:
# - LM Studio: http://127.0.0.1:1234/v1 (default port 1234)
# - OLLAMA: http://127.0.0.1:8001/v1 (custom port 8001)
# - OLLAMA default: http://127.0.0.1:11434/v1 (default port 11434)
# - OMLX: http://127.0.0.1:8000/v1 (default port 8000) - OpenAI-compatible MLX server
LLM_BASE_URL=http://127.0.0.1:8000/v1
LLM_MODEL=mlx-community/Qwen3.5-4B-MLX-4bit

# Option 4: Public LLM APIs (OpenAI, Anthropic, etc.)
# Set USE_MLX=false, USE_GGUF=false, and provide API key + base URL
# For OpenAI:
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o-mini
#   LLM_API_KEY=sk-...
# For Anthropic:
#   LLM_BASE_URL=https://api.anthropic.com/v1
#   LLM_MODEL=claude-3-5-sonnet-20241022
#   LLM_API_KEY=sk-ant-...
# For Groq:
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#   LLM_API_KEY=gsk_...
LLM_API_KEY=

# Common LLM Parameters (applies to all options)
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=32000

# Logging
LOG_LEVEL=INFO

# Made with Bob